{
  "_farosMemoryEnvelope": true,
  "data": {
    "seedQuery": "memory view",
    "paperType": "system",
    "targetVenue": "generic"
  },
  "summary": {},
  "scopes": {
    "run": [
      "paperType",
      "seedQuery",
      "targetVenue"
    ]
  },
  "history": [],
  "archives": {},
  "policy": {
    "mode": "persistent",
    "summary_keys": [
      "selectedCandidateId",
      "projectId",
      "experimentId",
      "paperId",
      "reviewId",
      "lastNodeId"
    ],
    "scope_strategy": "node",
    "max_history_entries": 32,
    "compaction_mode": "summary_only",
    "volatile_prefixes": [
      "tmp_",
      "draft_",
      "scratch_"
    ],
    "retained_scopes": [
      "run"
    ],
    "remove_archived_keys": false
  }
}