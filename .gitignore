# .gitignore for FAROS project
# Generated to ignore virtualenvs, build artifacts, secrets, and common OS/IDE files

*.json
backend/data/
backend/tests/

# Python
__pycache__/
**/__pycache__/
**/__pycache__/**
*.py[cod]
*$py.class
.Python
env/
venv/
.venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
*.egg
pip-wheel-metadata/
share/python-wheels/
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
.mypy_cache/
profile_default/
ipython_config.py
*.pyc
**/*.pyc

# Runtime / local data
/backend/data/provider_config.json
/.dev/
backend/.venv/
backend/data/**/__pycache__/

# LaTeX build artifacts (paper generation)
*.aux
*.bbl
*.blg
*.brf
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
*.xdv
*.nav
*.snm
*.vrb
latexmkrc
.latexmk/

# Node / frontend
node_modules/
/.pnp
.pnp.js
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env files and secrets
.env
.env.*
backend/.env
frontend/.env

# Editor directories and files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log
logs/

# Git metadata
*.orig

# Package artifacts
*.egg-info/
*.egg

# Misc
*.sqlite3
*.db
/.pytest_cache/
